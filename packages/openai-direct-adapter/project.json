{
  "name": "openai-direct-adapter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/openai-direct-adapter/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:adapter",
    "plane:execution"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "packages/openai-direct-adapter/dist",
        "main": "packages/openai-direct-adapter/src/index.ts",
        "tsConfig": "packages/openai-direct-adapter/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/openai-direct-adapter/src/**/*.ts",
          "packages/openai-direct-adapter/project.json",
          "packages/openai-direct-adapter/package.json"
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/packages/openai-direct-adapter"
      ],
      "options": {
        "command": "vitest run",
        "cwd": "packages/openai-direct-adapter"
      }
    }
  }
}
