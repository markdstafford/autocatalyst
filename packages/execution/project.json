{
  "name": "execution",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/execution/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:execution",
    "plane:execution"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "packages/execution/dist",
        "main": "packages/execution/src/index.ts",
        "tsConfig": "packages/execution/tsconfig.lib.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "packages/execution/src/skills/assets",
            "output": "src/skills/assets"
          }
        ]
      }
    },
    "verify-dist-assets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/execution/scripts/verify-dist-assets.mjs",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": [
        "build"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/execution/src/**/*.ts",
          "packages/execution/project.json",
          "packages/execution/package.json"
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/packages/execution"
      ],
      "options": {
        "command": "vitest run",
        "cwd": "packages/execution"
      }
    }
  }
}
