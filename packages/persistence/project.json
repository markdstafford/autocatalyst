{
  "name": "persistence",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/persistence/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:persistence",
    "plane:control"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}",
        "{options.outputPath}/index.d.ts"
      ],
      "options": {
        "outputPath": "packages/persistence/dist",
        "rootDir": "packages/persistence/src",
        "main": "packages/persistence/src/index.ts",
        "tsConfig": "packages/persistence/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "packages/persistence/src/**/*.ts",
          "packages/persistence/project.json",
          "packages/persistence/package.json"
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/packages/persistence"
      ],
      "options": {
        "command": "vitest run",
        "cwd": "packages/persistence"
      }
    }
  }
}
