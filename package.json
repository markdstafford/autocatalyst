    "fastify": "^5.8.5",
    "zod": "^3.25.64"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "nx"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@nx/eslint": "21.1.2",
    "@nx/eslint-plugin": "21.1.2",
    "@nx/js": "21.1.2",
    "@nx/vite": "21.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.28.0",
    "jsonc-eslint-parser": "^3.1.0",
    "nx": "21.1.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5",
    "@vitest/coverage-v8": "^3.2.2",
    "vitest": "^3.2.2"
  }
