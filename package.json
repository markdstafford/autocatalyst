    "@nx/vite": "21.1.2",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "nx": "21.1.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.2"
  }
