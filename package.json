{
  "name": "autocatalyst",
  "version": "0.0.1",
  "description": "AI-led development loop: idea → spec → approval → implementation → evaluation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "autocatalyst": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:core": "vitest run tests/core/",
    "test:adapters": "vitest run tests/adapters/",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.28.1",
    "@aws-sdk/credential-providers": "^3.1029.0",
    "@anthropic-ai/sdk": "^0.88.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.105",
    "@notionhq/client": "^5.17.0",
    "@slack/bolt": "^4.7.0",
    "pino": "9.6.0",
    "yaml": "2.7.1"
  },
  "devDependencies": {
    "@types/node": "22.14.1",
    "tsx": "4.19.3",
    "typescript": "5.8.3",
    "vitest": "3.1.1"
  }
}
